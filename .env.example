# 未設定でもフォールバック講評で完全に動作します。
# 設定した場合のみ、結果画面の短評生成にサーバー側からOpenAI APIを使用します。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ランキング用。Secretキーはサーバー専用で、NEXT_PUBLIC_を付けないでください。
SUPABASE_URL=
# 推奨: Settings > API Keys の sb_secret_... 形式
SUPABASE_SECRET_KEY=
# 旧形式を使う既存プロジェクトのみ（SUPABASE_SECRET_KEYが優先されます）
SUPABASE_SERVICE_ROLE_KEY=
